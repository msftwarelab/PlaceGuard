# ===========================================================================
# PlaceGuard — Environment Variables
# Copy to .env and fill in your API keys
# ===========================================================================

# ---- LLM Provider (set at least one) ----
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# GOOGLE_API_KEY=your-gemini-key-here

# ---- Default LLM model (optional overrides) ----
# OPENAI_MODEL=gpt-4-turbo-preview
# ANTHROPIC_MODEL=claude-3-opus-20240229
# GEMINI_MODEL=gemini-pro

# ---- FastAPI settings ----
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ---- Streamlit settings ----
DASHBOARD_API_BASE_URL=http://localhost:8000

# ---- Database (optional, defaults to in-memory mock) ----
# DATABASE_URL=postgresql://user:password@localhost:5432/placeguard

# ---- Redis (optional, defaults to in-memory rate limiting) ----
# REDIS_URL=redis://localhost:6379/0

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---- Security ----
# API_KEY=your-secret-api-key-for-production
